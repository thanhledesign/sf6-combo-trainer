# =============================================================================
# SF6 Combo Trainer — Environment Variables
# =============================================================================

# Site password (optional — protects the app behind a simple password gate).
# Defaults to 'shoryuken' if unset. Set this in Vercel → Settings →
# Environment Variables (production AND preview environments) before
# merging to main, or anyone can guess the default and bypass the gate.
VITE_SITE_PASSWORD=shoryuken
